  <diagram name="2-Promotions Payment Loyalty" id="Y85Iaiz7Z2sYD267uYe4">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3200" pageHeight="2200" math="0" shadow="0">
