        <mxCell id="_UJ83jsw6JJzsuaWNcb1-5" value="User&#xa;------------------------------&#xa;PK _id:ObjectId&#xa;username:String [req]&#xa;full_name:String OPT&#xa;email:String OPT [UQ partial index]&#xa;phone:String OPT&#xa;password_hash:String OPT&#xa;avatar:String OPT&#xa;role_id:Number DEF(3) [legacy alias role]&#xa;role_key:String OPT [alias]&#xa;permissions:[String] DEF([]) [denorm]&#xa;branch_id:Mixed OPT FK-&gt;Branch&#xa;lotte_points:Number DEF(0) [computed]&#xa;membership_level:String DEF(&#39;Dong&#39;)&#xa;signup_method, login_provider&#xa;googleId, facebookId, facebook_id [legacy], social_providers[]&#xa;status:String DEF(ACTIVE), is_active:Boolean DEF(true)&#xa;profile_completed:Boolean DEF(false) [computed]&#xa;wallet_balance:Number DEF(0) [computed]&#xa;default_payment_method:{type,last4,brand,card_id} [snapshot]&#xa;email_verified + otp fields&#xa;preferences{}, security{}, settings{}&#xa;last_login_at, refresh_token&#xa;created_at, updated_at&#xa;IDX partial unique(email)" style="rounded=1;whiteSpace=wrap;html=0;align=left;verticalAlign=top;spacing=8;fillColor=#dcfce7;strokeColor=#334155;fontSize=11;fontFamily=Consolas;" vertex="1" parent="1">
