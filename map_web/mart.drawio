        <mxCell id="_UJ83jsw6JJzsuaWNcb1-6" value="Address&#xa;------------------------------&#xa;PK _id:ObjectId&#xa;FK user_id:Mixed [req,index]-&gt;User&#xa;name:String [req]&#xa;phone:String OPT&#xa;street, ward, district, city:String&#xa;full_address:String [denorm]&#xa;is_default:Boolean DEF(false)&#xa;label:String DEF(home)&#xa;created_at, updated_at" style="rounded=1;whiteSpace=wrap;html=0;align=left;verticalAlign=top;spacing=8;fillColor=#dcfce7;strokeColor=#334155;fontSize=11;fontFamily=Consolas;" vertex="1" parent="1">
