        <mxCell id="_UJ83jsw6JJzsuaWNcb1-10" value="BranchProduct&#xa;------------------------------&#xa;PK _id:ObjectId&#xa;FK product_id:Mixed [req]-&gt;Product&#xa;FK branch_id:Mixed [req]-&gt;Branch&#xa;master_id, sku [legacy]&#xa;category_id, category_name [snapshot]&#xa;supplier_id, supplier_name [snapshot]&#xa;price, original_price, import_price, discount_percent&#xa;stock, min_stock, max_purchase_limit&#xa;is_available:Boolean DEF(true)&#xa;sold_count:Number DEF(0) [computed]&#xa;manufacture_date, expiry_date, batch_code&#xa;is_expiring_soon, is_expired&#xa;promotion_tag, promotion_end_date&#xa;created_at, updated_at&#xa;[observed-in-db/frontend-used] badges[], policies{}, lead_time_days, status, last_updated (not schema)&#xa;NOTE: Drift: badges/policies/status/last_updated are used in frontend and API payload but not defined in schema." style="rounded=1;whiteSpace=wrap;html=0;align=left;verticalAlign=top;spacing=8;fillColor=#fef3c7;strokeColor=#334155;fontSize=11;fontFamily=Consolas;" vertex="1" parent="1">
          <mxGeometry x="1040" y="899.4999999999998" width="420" height="272" as="geometry" />
        </mxCell>
        <mxCell id="_UJ83jsw6JJzsuaWNcb1-11" value="Cart&#xa;------------------------------&#xa;PK _id:ObjectId&#xa;FK user_id:ObjectId [req]-&gt;User&#xa;FK branch_id:String [req]-&gt;Branch&#xa;items[]:&#xa;  - FK branch_product_id:Mixed [req]-&gt;BranchProduct&#xa;  - quantity:Number DEF(1)&#xa;  - price:Number DEF(0) [snapshot]&#xa;  - unit_price:Number DEF(0) [snapshot]&#xa;  - product_name, product_image [snapshot]&#xa;created_at, updated_at&#xa;IDX UQ(user_id,branch_id)" style="rounded=1;whiteSpace=wrap;html=0;align=left;verticalAlign=top;spacing=8;fillColor=#e0f2fe;strokeColor=#334155;fontSize=11;fontFamily=Consolas;" vertex="1" parent="1">
