        </mxCell>
        <mxCell id="_UJ83jsw6JJzsuaWNcb1-12" value="Order&#xa;------------------------------&#xa;PK _id:ObjectId&#xa;FK user_id:Mixed [req]-&gt;User&#xa;items[] (OrderItem snapshot):&#xa;  branch_product_id, product_id, product_name, product_image, sku&#xa;  category_name, supplier_name, expiry_date&#xa;  quantity, price, original_price, unit_price, final_price&#xa;  discount_amount, discount_applied, discount [legacy], is_gift&#xa;order_address:{receiver_name,phone,full_address,city,district,ward,note}&#xa;status enum(PENDING..RETURNED)&#xa;subtotal, shipping_fee, discount_amount, total_amount&#xa;coupon_code, points_earned&#xa;payment:{method,status,transaction_id}&#xa;tracking:{tracking_number,carrier,estimated_delivery,history[]}&#xa;delivery_slot:Mixed FK-&gt;DeliverySlot&#xa;branch_id, branch_name&#xa;pricing_breakdown{subtotal,item_discounts,promotion_discount,coupon_discount,shipping_fee,free_shipping_applied,points_earned,final_total}&#xa;applied_promotions[], applied_coupon{}, gift_items[]&#xa;note, generated_invoice_url&#xa;email_notification_status/sent_at/error&#xa;created_at, updated_at&#xa;IDX (user_id,status,created_at)&#xa;[frontend-used/observed] payment_method, payment_status, payment_transaction_id, vat_percent, vat_amount, tax_amount, is_pickup, qr_code_url, delivery_type, shipping_provider&#xa;NOTE: Order keeps many denormalized snapshots for auditability; legacy flat payment/tax aliases still used by frontend." style="rounded=1;whiteSpace=wrap;html=0;align=left;verticalAlign=top;spacing=8;fillColor=#e0f2fe;strokeColor=#334155;fontSize=11;fontFamily=Consolas;" vertex="1" parent="1">
          <mxGeometry x="1560" y="1026.9999999999998" width="420" height="370" as="geometry" />
        </mxCell>
