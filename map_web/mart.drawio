        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="28" value="Promotions / Payment / Loyalty" style="rounded=1;whiteSpace=wrap;html=0;fillColor=#111827;fontColor=#ffffff;strokeColor=#111827;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="860" height="44" as="geometry" />
        </mxCell>
        <mxCell id="29" value="Legend:&#xa;PK = Primary Key&#xa;FK = Foreign Key&#xa;UQ = Unique&#xa;OPT = Optional&#xa;DEF(x) = Default&#xa;IDX(...) = Index&#xa;Tags: [snapshot], [denorm], [computed], [legacy], [mixed], [ambiguous], [observed-in-db], [frontend-used], [alias]" style="rounded=1;whiteSpace=wrap;html=0;align=left;verticalAlign=top;fillColor=#f8fafc;strokeColor=#94a3b8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="900" y="20" width="1680" height="74" as="geometry" />
        </mxCell>
        <mxCell id="30" value="Promotion&#xa;------------------------------&#xa;PK _id:ObjectId&#xa;title:String [req], description&#xa;type enum(percent,fixed_amount,bogo,free_shipping,points_multiplier,gift_item,flash_deal)&#xa;voucher_type enum(product,shipping) DEF(product)&#xa;status enum(draft,active,scheduled,expired,paused) DEF(active)&#xa;start_date, end_date, is_active, priority&#xa;scope enum(all,product,category,branch)&#xa;target_product_ids[], target_category_ids[], target_branch_ids[]&#xa;excluded_product_ids[], excluded_category_ids[]&#xa;is_auto_generated, source, suggested_by_system&#xa;total_quantity, remaining_quantity, claimed_count&#xa;hide_after_expired_hours, auto_hide_after_expired, notification_sent&#xa;usage_limit, max_redemptions, usage_count, usage_per_user&#xa;min_order_amount, min_quantity, gift_quantity&#xa;discount_value, max_discount_amount, gift_product_id, points_multiplier&#xa;badge_text, banner_image, image, banner_url&#xa;claim_campaign, stackable&#xa;created_by:ObjectId FK-&gt;User&#xa;created_at, updated_at&#xa;IDX (is_active,status,start_date,end_date,priority)&#xa;IDX scope&#xa;[schema defect] scope + target_* duplicated in same schema declaration&#xa;NOTE: Promotion schema duplicates scope/target fields; include as known defect." style="rounded=1;whiteSpace=wrap;html=0;align=left;verticalAlign=top;spacing=8;fillColor=#fee2e2;strokeColor=#334155;fontSize=11;fontFamily=Consolas;" vertex="1" parent="1">
