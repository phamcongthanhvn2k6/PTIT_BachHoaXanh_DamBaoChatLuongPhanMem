        <mxCell id="_UJ83jsw6JJzsuaWNcb1-9" value="Branch&#xa;------------------------------&#xa;PK _id:ObjectId&#xa;name:String [req]&#xa;address, city, phone, manager:String&#xa;is_active:Boolean DEF(true)&#xa;operating_hours:String DEF(08:00-22:00)&#xa;opening_hours:String [frontend-used alias observed]&#xa;coordinates:{lat,lng}&#xa;createdAt, updatedAt" style="rounded=1;whiteSpace=wrap;html=0;align=left;verticalAlign=top;spacing=8;fillColor=#fef3c7;strokeColor=#334155;fontSize=11;fontFamily=Consolas;" vertex="1" parent="1">
