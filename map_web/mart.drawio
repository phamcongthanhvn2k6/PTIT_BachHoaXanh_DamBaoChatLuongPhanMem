        <mxCell id="_UJ83jsw6JJzsuaWNcb1-7" value="Category&#xa;------------------------------&#xa;PK _id:ObjectId&#xa;name:String [req]&#xa;slug:String OPT&#xa;icon,image,banner:String OPT&#xa;description:String OPT&#xa;parent_id:Mixed OPT FK-&gt;Category&#xa;sort_order:Number DEF(0)&#xa;display_order:Number DEF(0) [alias/split]&#xa;is_active:Boolean DEF(true)&#xa;product_count:Number DEF(0) [computed]&#xa;created_by:Mixed OPT FK-&gt;User&#xa;createdAt, updatedAt" style="rounded=1;whiteSpace=wrap;html=0;align=left;verticalAlign=top;spacing=8;fillColor=#fef3c7;strokeColor=#334155;fontSize=11;fontFamily=Consolas;" vertex="1" parent="1">
