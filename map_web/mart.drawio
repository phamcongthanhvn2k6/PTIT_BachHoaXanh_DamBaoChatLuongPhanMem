        <mxCell id="_UJ83jsw6JJzsuaWNcb1-3" value="Role&#xa;------------------------------&#xa;PK _id:ObjectId&#xa;key:String [req,UQ]&#xa;name:String [req]&#xa;description:String OPT DEF(&#39;&#39;)&#xa;role_id:Number OPT [legacy]&#xa;permissions:[String] DEF([]) [denorm FK-&gt;Permission.key]&#xa;is_system:Boolean DEF(false)&#xa;is_active:Boolean DEF(true)&#xa;created_at, updated_at&#xa;IDX key&#xa;IDX role_id" style="rounded=1;whiteSpace=wrap;html=0;align=left;verticalAlign=top;spacing=8;fillColor=#dbeafe;strokeColor=#334155;fontSize=11;fontFamily=Consolas;" vertex="1" parent="1">
