        <mxCell id="_UJ83jsw6JJzsuaWNcb1-8" value="Product&#xa;------------------------------&#xa;PK _id:ObjectId&#xa;name:String [req], slug:String&#xa;description, short_description&#xa;eco_label:Mixed [ambiguous]&#xa;FK category_id:Mixed -&gt;Category&#xa;category_name:String [denorm]&#xa;FK supplier_id:Mixed -&gt;Supplier&#xa;supplier_name:String [denorm]&#xa;master_id:String [legacy]&#xa;brand, origin, origin_country [alias], origin_flag&#xa;unit, weight, barcode, sku&#xa;price:Number [req], original_price, import_price, discount_percent&#xa;images[], gallery[], ar_model_url, thumbnail&#xa;tags[], vat_included, shipping_excluded&#xa;is_active, is_featured, is_best_seller, is_new&#xa;rating, review_count, total_reviews [legacy alias average_rating]&#xa;rating_breakdown:Mixed [computed]&#xa;stock, sold_count [computed/denorm]&#xa;manufacture_date, expiry_date, batch_code, is_expiring_soon, is_expired&#xa;highlights[], product_details[], specifications:Mixed&#xa;nutrition_info:Mixed, usage_guide, storage_instructions, storage_guide [alias]&#xa;notes, recipe_suggestions[]&#xa;related_product_ids[], frequently_bought_together[]&#xa;created_by:Mixed FK-&gt;User, created_at, updated_at&#xa;IDX text(name,description,brand)" style="rounded=1;whiteSpace=wrap;html=0;align=left;verticalAlign=top;spacing=8;fillColor=#fef3c7;strokeColor=#334155;fontSize=11;fontFamily=Consolas;" vertex="1" parent="1">
